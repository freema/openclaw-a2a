# OpenClaw Gateway
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Model name for chat completions (default: openclaw)
# Gateway versions 2026.3.24+ require "openclaw" or "openclaw/<agentId>"
# OPENCLAW_MODEL=openclaw

# Multi-instance (JSON array, has priority over single instance)
# OPENCLAW_INSTANCES=[{"name":"prod","url":"http://127.0.0.1:18789","token":"...","default":true}]

# Server
PORT=3100
HOST=0.0.0.0
DEBUG=false

# Agent Card
PUBLIC_URL=http://localhost:3100
